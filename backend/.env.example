# Backend Environment Variables — Copy to backend/.env (never commit the real .env!)

# Server
PORT=4000
NODE_ENV=development

# MongoDB (Required)
# Local:  mongodb://localhost:27017/groovy-bugs
# Cloud:  mongodb+srv://<user>:<password>@cluster.mongodb.net/groovy-bugs
MONGODB_URI=mongodb://localhost:27017/groovy-bugs

# Frontend CORS origin (Required)
# Local development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Clerk Authentication (Required — get from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# JWT Secret — only used by legacy /api/auth routes (Clerk handles production auth)
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string
