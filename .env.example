# Frontend Environment Variables — Copy to .env (never commit the real .env!)

# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── WhatsApp Ordering ───────────────────────────────────────────────────────
# The shop owner's WhatsApp number (with country code, digits only)
# Example: India +91 98765 43210 → 919876543210
VITE_OWNER_WHATSAPP_NUMBER=919876543210

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Your own Clerk User ID — found at dashboard.clerk.com → Users → click yourself
# Route /admin/orders and /admin/discounts are only accessible to this user ID
VITE_ADMIN_CLERK_ID=user_xxxxxxxxxxxxxxxxxxxx

# ─── EmailJS (optional — for order confirmation emails) ──────────────────────
# Get from: https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ─── API Base URL (leave empty for local Vite proxy, set for production) ─────
# Local:      (leave blank — Vite proxies /api to http://127.0.0.1:4000)
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=
